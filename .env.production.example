# Copy to .env in repo root for production: cp .env.production.example .env
# Generate secrets: openssl rand -hex 32

DOMAIN=sciconnect.example.ru
POSTGRES_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-use-openssl-rand-hex-32

DATABASE_URL=postgresql://sciconnect:${POSTGRES_PASSWORD}@db:5432/sciconnect
REDIS_URL=redis://redis:6379

FRONTEND_URL=https://${DOMAIN}
CORS_ORIGINS=https://${DOMAIN}
NEXT_PUBLIC_API_URL=https://${DOMAIN}/api

# Yandex Mail example (port 465 = SSL)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_FROM=noreply@your-domain.ru
SMTP_FROM_NAME=SciConnect
SMTP_USER=noreply@your-domain.ru
SMTP_PASSWORD=your-mailbox-password

EMAIL_ASYNC=true
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_QUEUE_KEY=sciconnect:email

DEBUG=false
SEED_DEMO=true
PAYMENT_PROVIDER=demo
COOKIE_SECURE=true
