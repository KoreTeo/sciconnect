# Database
DATABASE_URL=postgresql://sciconnect:sciconnect123@db:5432/sciconnect

# JWT
SECRET_KEY=change-me-in-production

# Redis
REDIS_URL=redis://redis:6379

# SMTP (dev: Mailhog on localhost:1025, UI http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@sciconnect.local
SMTP_FROM_NAME=SciConnect

# Email queue (true = ARQ worker; false = sync SMTP in API process, for tests)
EMAIL_ASYNC=true
EMAIL_QUEUE_KEY=sciconnect:email

# Frontend base URL for links in emails
FRONTEND_URL=http://localhost:3000

# Comma-separated CORS origins (production: https://your-domain.ru)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP TLS: port 587 + SMTP_USE_TLS=true, or port 465 + SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Require verified email for paper submit and conference registration
EMAIL_VERIFICATION_REQUIRED=true

# Set false for E2E / local demo without email verification gates
# EMAIL_VERIFICATION_REQUIRED=false

DEBUG=true
